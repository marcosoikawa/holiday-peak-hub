# ---------------------------------------------------------------------------
# Demo pipeline environment variables
# Copy to scripts/demo/.env and fill in values for your environment.
# ---------------------------------------------------------------------------

# APIM base URL (used by CRUD and catalog-search calls)
APIM_BASE_URL=https://<your-apim>.azure-api.net

# CRUD service URL (Step 1 — export products CSV in live mode)
# Not needed when running with --mock (default).
CRUD_SERVICE_URL=https://<your-apim>.azure-api.net/api

# Catalog-search agent URL (Step 4 — validate search queries)
# Passed as --catalog-url to validate_search.py
CATALOG_SEARCH_URL=https://<your-apim>.azure-api.net/agents/ecommerce-catalog-search

# Azure Blob Storage account URL (Step 2 — upload CSV)
BLOB_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net/

# Blob container for raw product data (defaults to raw_data if unset)
TRUTH_PRODUCT_BLOB_CONTAINER=raw-data

# Event Hub — one of NAMESPACE or CONNECTION_STRING is required (Step 2)
# Namespace uses DefaultAzureCredential; connection string uses SAS/key auth.
PLATFORM_JOBS_EVENT_HUB_NAMESPACE=<your-jobs-eventhub>.servicebus.windows.net
# PLATFORM_JOBS_EVENT_HUB_CONNECTION_STRING=Endpoint=sb://...
