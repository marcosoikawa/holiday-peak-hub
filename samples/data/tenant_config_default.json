{
  "tenant_id": "tenant-default",
  "display_name": "Holiday Peak Hub (Default Tenant)",
  "environment": "development",
  "cosmos_database": "truth-store",
  "containers": {
    "products": "products",
    "schemas": "schemas",
    "audit": "audit",
    "queue": "hitl-queue",
    "exports": "exports"
  },
  "event_hub": {
    "namespace": "holidaypeak-eh",
    "topics": {
      "ingest_jobs": "ingest-jobs",
      "gap_jobs": "gap-jobs",
      "enrichment_jobs": "enrichment-jobs",
      "hitl_queue": "hitl-queue",
      "export_jobs": "export-jobs"
    }
  },
  "completeness": {
    "auto_approve_threshold": 0.95,
    "human_review_threshold": 0.70,
    "low_completeness_threshold": 0.50
  },
  "export": {
    "enabled_protocols": ["acp_v1", "ucp_v1"],
    "default_protocol": "acp_v1"
  },
  "partner_policies": {
    "default": {
      "restricted_fields": [],
      "allowed_categories": ["apparel", "electronics", "general"]
    }
  },
  "sources": {
    "pim": {
      "type": "generic_rest",
      "base_url": "http://localhost:8080/pim",
      "auth_type": "api_key",
      "field_mappings": {
        "style_id": "id",
        "name": "title",
        "brand": "brand_name",
        "category": "category_code",
        "price": "base_price",
        "currency": "price_currency"
      }
    },
    "dam": {
      "type": "generic_rest",
      "base_url": "http://localhost:8080/dam",
      "auth_type": "api_key",
      "supported_renditions": ["thumbnail", "medium", "full", "zoom"]
    }
  }
}
