{
  "schema_id": "electronics-v1",
  "category": "electronics",
  "version": "1.0.0",
  "display_name": "Electronics",
  "description": "Category schema for consumer electronics and accessories",
  "required_fields": [
    "style_id",
    "name",
    "brand",
    "category",
    "model_number",
    "connectivity",
    "power_source",
    "price",
    "currency",
    "image_url",
    "description",
    "warranty_months"
  ],
  "optional_fields": [
    "dimensions_mm",
    "weight_grams",
    "compatible_with",
    "operating_system",
    "processor",
    "storage_gb",
    "ram_gb",
    "battery_life_hours",
    "color_options",
    "country_of_origin",
    "certification",
    "tags",
    "rating",
    "review_count"
  ],
  "variant_required_fields": [
    "variant_id",
    "sku",
    "color",
    "storage_gb",
    "stock_quantity",
    "price"
  ],
  "variant_optional_fields": [
    "ram_gb",
    "barcode",
    "image_url"
  ],
  "field_definitions": {
    "style_id": {"type": "string", "description": "Unique product style identifier"},
    "name": {"type": "string", "description": "Product display name"},
    "brand": {"type": "string", "description": "Manufacturer or brand name"},
    "category": {"type": "string", "description": "Product category"},
    "model_number": {"type": "string", "description": "Manufacturer model number"},
    "connectivity": {"type": "array", "items": {"type": "string"}, "description": "Connectivity options (WiFi, Bluetooth, USB-C, etc.)"},
    "power_source": {"type": "string", "enum": ["battery", "wired", "both"], "description": "Power source type"},
    "price": {"type": "number", "minimum": 0, "description": "Base price"},
    "currency": {"type": "string", "description": "Price currency code"},
    "image_url": {"type": "string", "format": "uri", "description": "Primary product image URL"},
    "description": {"type": "string", "description": "Product description"},
    "warranty_months": {"type": "integer", "minimum": 0, "description": "Warranty duration in months"},
    "dimensions_mm": {"type": "object", "description": "Physical dimensions (length, width, height) in mm"},
    "weight_grams": {"type": "integer", "minimum": 0, "description": "Product weight in grams"},
    "compatible_with": {"type": "array", "items": {"type": "string"}, "description": "Compatible platforms or devices"},
    "operating_system": {"type": "string", "description": "Operating system (if applicable)"},
    "processor": {"type": "string", "description": "Processor model"},
    "storage_gb": {"type": "integer", "minimum": 0, "description": "Storage capacity in GB"},
    "ram_gb": {"type": "integer", "minimum": 0, "description": "RAM in GB"},
    "battery_life_hours": {"type": "number", "minimum": 0, "description": "Battery life in hours"},
    "color_options": {"type": "array", "items": {"type": "string"}, "description": "Available colors"},
    "country_of_origin": {"type": "string", "description": "Manufacturing country"},
    "certification": {"type": "array", "items": {"type": "string"}, "description": "Safety/compliance certifications (CE, FCC, etc.)"},
    "tags": {"type": "array", "items": {"type": "string"}, "description": "Searchable tags"},
    "rating": {"type": "number", "minimum": 0, "maximum": 5, "description": "Average customer rating"},
    "review_count": {"type": "integer", "minimum": 0, "description": "Number of customer reviews"}
  }
}
