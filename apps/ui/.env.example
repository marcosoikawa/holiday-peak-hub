# ============================================================
# Holiday Peak Hub – UI Environment Variables
# Copy this file to .env.local for local development.
# Never commit .env.local to source control.
# ============================================================

# ------------------------------------------------------------
# Microsoft Entra ID (Azure AD) – Authentication
# Required for user login via MSAL.
# Leave blank to run in anonymous/guest mode (Entra is optional
# for local development; the UI will log a debug message and
# continue without authentication).
#
# Steps to obtain these values:
#   1. Register an app in Azure Portal → Entra ID → App registrations.
#   2. Copy the "Application (client) ID" → NEXT_PUBLIC_ENTRA_CLIENT_ID.
#   3. Copy the "Directory (tenant) ID"   → NEXT_PUBLIC_ENTRA_TENANT_ID.
#   See docs/implementation/entra-id-setup.md for full instructions.
# ------------------------------------------------------------
NEXT_PUBLIC_ENTRA_CLIENT_ID=
NEXT_PUBLIC_ENTRA_TENANT_ID=

# ------------------------------------------------------------
# Dev-only mock authentication
# Enables role-selectable mock login at /auth/login with signed
# auth cookie support. Disabled automatically in production.
# In this mode, browser API calls also include explicit X-Dev-Auth-*
# headers so protected CRUD endpoints continue to work locally without
# an Entra bearer token.
# Requires CRUD service DEV_AUTH_MOCK=true with ENVIRONMENT=dev.
# Set both flags to true for local development mock mode.
# ------------------------------------------------------------
DEV_AUTH_MOCK=false
NEXT_PUBLIC_DEV_AUTH_MOCK=false

# Signing secret for auth cookie verification in middleware and
# mock auth endpoints. Required in production runtime.
AUTH_COOKIE_SECRET=

# ------------------------------------------------------------
# Backend API URLs
# NEXT_PUBLIC_CRUD_API_URL  – Base URL for the CRUD/REST service.
# NEXT_PUBLIC_AGENT_API_URL – Base URL for the Agent service
#                             (falls back to <CRUD_URL>/agents when unset).
# In non-local runtime, UI proxy routes enforce APIM-only URLs
# (*.azure-api.net). Local loopback URLs are allowed only when
# NODE_ENV is not production.
# ------------------------------------------------------------
NEXT_PUBLIC_CRUD_API_URL=http://localhost:8000
NEXT_PUBLIC_AGENT_API_URL=

# Optional local-development override to allow non-APIM proxy targets.
# Never enable this in production.
UI_ALLOW_NON_APIM_PROXY_URL=false
