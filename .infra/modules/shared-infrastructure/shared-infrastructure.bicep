  {
    name: 'products'
    paths: ['/categoryId']
  }
  {
    name: 'search_enriched_products'
    paths: ['/categoryId']
  }
  {
    name: 'attributes_truth'
    paths: ['/entityId']
  }
  {
    name: 'attributes_proposed'
    paths: ['/entityId']
  }
  {
    name: 'assets'
    paths: ['/productId']
  }
  {
    name: 'evidence'
    paths: ['/entityId']
  }
  {
    name: 'schemas'
    paths: ['/categoryId']
  }
  {
